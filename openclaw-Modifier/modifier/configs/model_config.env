# ============================================
# 🤖 CONFIGURACIÓN DEL MODELO LOCAL
# ============================================
# Este archivo define la configuración para tu modelo llama.cpp

# ============================================
# MODELO
# ============================================

# Ruta completa a tu archivo de modelo GGUF
# Ejemplo para macOS: /Users/tu-usuario/modelos/mistral-7b-instruct-v0.1.Q6_K.gguf
# Ejemplo para Linux: /home/tu-usuario/modelos/mistral-7b-instruct-v0.1.Q6_K.gguf
MODEL_PATH="/Users/gustavosilvadacosta/modelo/modelos_grandes/M6/mistral-7b-instruct-v0.1.Q6_K.gguf"

# Nombre identificador del modelo (sin espacios, usar guiones)
MODEL_NAME="mistral-7b"

# ============================================
# LLAMA.CPP BINARIO
# ============================================

# Ruta al ejecutable llama-server
# Ejemplo para macOS: /Users/tu-usuario/llama.cpp/build/bin/llama-server
# Ejemplo para Linux: /home/tu-usuario/llama.cpp/build/bin/llama-server
LLAMA_BIN="$HOME/modelo/llama.cpp/build/bin/llama-server"

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

# Puerto base para llama-server
# Single agent: usará BASE_PORT
# Multi agent: usará BASE_PORT, BASE_PORT+1, BASE_PORT+2
BASE_PORT=8080

# Tamaño del contexto en tokens
# 2048 = mínimo, 4096 = recomendado, 8192+ = para conversaciones largas
CONTEXT_SIZE=4096

# Número de threads de CPU a usar
# Recomendado: número de cores de tu CPU (o la mitad si tienes hyperthreading)
THREADS=8

# ============================================
# MULTI-AGENTE (opcional)
# ============================================

# Nombres de los agentes (para multi-agente)
AGENT_1_NAME="daneel"
AGENT_2_NAME="dors"
AGENT_3_NAME="giskard"

# Puertos para cada agente (para multi-agente)
AGENT_1_PORT=8080
AGENT_2_PORT=8081
AGENT_3_PORT=8082

# ============================================
# OPENCLAW
# ============================================

# Puerto del dashboard de OpenClaw
OPENCLAW_PORT=3000

# Nivel de log (debug, info, warn, error)
LOG_LEVEL="info"

# ============================================
# NOTAS
# ============================================
# - Asegúrate de que MODEL_PATH apunta a un archivo .gguf válido
# - Verifica que LLAMA_BIN existe y tiene permisos de ejecución
# - Los puertos deben estar libres (no usados por otros servicios)
# - Ajusta THREADS según tu CPU (usa `sysctl -n hw.ncpu` en macOS o `nproc` en Linux)
# - Para multi-agente, asegúrate de tener suficiente RAM (8GB+ por instancia)
